<Window x:Class="ProductivityWallpaper.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ProductivityWallpaper.ViewModels"
        xmlns:models="clr-namespace:ProductivityWallpaper.Models"
        mc:Ignorable="d"
        Title="Preview"
        Height="600"
        Width="800"
        MinWidth="400"
        MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundMainBrush}"
        d:DataContext="{d:DesignInstance Type=models:MediaItemModel}">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Media Type Converters -->
        <vm:MediaTypeIsImageConverter x:Key="MediaTypeIsImageConverter"/>
        <vm:MediaTypeIsVideoConverter x:Key="MediaTypeIsVideoConverter"/>
        <vm:MediaTypeIsAudioConverter x:Key="MediaTypeIsAudioConverter"/>
        
        <!-- Window Button Style -->
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Close Button Style -->
        <Style x:Key="WindowCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Control Button Style -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundBlockBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundSelectedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Title Bar -->
            <RowDefinition Height="*"/>          <!-- Content Area -->
            <RowDefinition Height="Auto"/>      <!-- Control Bar (for audio) -->
        </Grid.RowDefinitions>
        
        
        <!-- Custom Title Bar -->
        
        <Grid Grid.Row="0" 
              Background="{StaticResource BackgroundBlockBrush}"
              Height="32">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            
            <!-- Window Title -->
            
            <TextBlock Grid.Column="0"
                      Text="{Binding FileName, StringFormat='Preview - {0}'}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      FontSize="12"
                      VerticalAlignment="Center"
                      Margin="16,0"
                      TextTrimming="CharacterEllipsis">
            </TextBlock>
            
            
            <!-- Window Controls -->
            
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal">
                
                
                <!-- Minimize Button -->
                
                <Button Style="{StaticResource WindowButtonStyle}"
                        Click="MinimizeButton_Click">
                    
                    <Path Data="M0 6H10"
                          Stroke="{StaticResource IconBrush}"
                          StrokeThickness="1"
                          Width="10"
                          Height="2"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
                
                
                <!-- Maximize/Restore Button -->
                
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource WindowButtonStyle}"
                        Click="MaximizeButton_Click">
                    
                    <Path x:Name="MaximizeIcon"
                          Data="M0 0H10V10H0V0ZM1 1V9H9V1H1Z"
                          Stroke="{StaticResource IconBrush}"
                          StrokeThickness="1"
                          Width="10"
                          Height="10"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
                
                
                <!-- Close Button -->
                
                <Button Style="{StaticResource WindowCloseButtonStyle}"
                        Click="CloseButton_Click">
                    
                    <Path Data="M0 0L10 10M10 0L0 10"
                          Stroke="{StaticResource IconBrush}"
                          StrokeThickness="1.5"
                          Width="10"
                          Height="10"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
        
        
        <!-- Content Area -->
        
        
        <Grid Grid.Row="1" 
              Background="Black">
            
            
            <!-- Image Preview -->
            
            
            <Image x:Name="PreviewImage"
                 Source="{Binding FilePath}"
                 Stretch="Uniform"
                 Visibility="{Binding Type, Converter={StaticResource MediaTypeIsImageConverter}}">
            </Image>
            
            
            <!-- Video Preview -->
            
            
            <MediaElement x:Name="PreviewVideo"
                         Source="{Binding FilePath}"
                         LoadedBehavior="Manual"
                         UnloadedBehavior="Manual"
                         Stretch="Uniform"
                         Visibility="{Binding Type, Converter={StaticResource MediaTypeIsVideoConverter}}">
            
            </MediaElement>
            
            
            <!-- Audio Preview -->
            
            
            <Grid Visibility="{Binding Type, Converter={StaticResource MediaTypeIsAudioConverter}}">
                
                
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    
                    
                    <!-- Music Icon -->
                    
                    
                    <Path Data="M12 3V13.55C11.41 13.21 10.73 13 10 13C8.34 13 7 14.34 7 16C7 17.66 8.34 19 10 19C11.66 19 13 17.66 13 16V5H18V3H12Z"
                          Fill="{StaticResource IconBrush}"
                          Width="96"
                          Height="96"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,24"/>
                    
                    
                    <!-- File Name -->
                    
                    
                    <TextBlock Text="{Binding FileName}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="16"
                              TextAlignment="Center"
                              TextTrimming="CharacterEllipsis"
                              MaxWidth="400">
                    </TextBlock>
                
                </StackPanel>
            
            </Grid>
        
        </Grid>
        
        
        <!-- Control Bar (for Video/Audio) -->
        
        
        <Grid Grid.Row="2" 
              Background="{StaticResource BackgroundBlockBrush}"
              Height="64"
              Visibility="{Binding Type, Converter={StaticResource MediaTypeIsImageConverter}, ConverterParameter=Invert}">
            
            
            <Grid.ColumnDefinitions>
                
                <ColumnDefinition Width="*"/>
                
                <ColumnDefinition Width="Auto"/>
                
                <ColumnDefinition Width="*"/>
            
            </Grid.ColumnDefinitions>
            
            
            <!-- Time Display -->
            
            
            <TextBlock Grid.Column="0"
                      x:Name="CurrentTimeText"
                      Text="0:00"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontSize="12"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Left"
                      Margin="16,0">
            </TextBlock>
            
            
            <!-- Playback Controls -->
            
            
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                
                
                <!-- Play/Pause Button -->
                
                
                <Button x:Name="PlayPauseButton"
                        Style="{StaticResource ControlButtonStyle}"
                        Click="PlayPauseButton_Click">
                    
                    
                    <Grid>
                        
                        
                        <!-- Play Icon -->
                        
                        
                        <Path x:Name="PlayIcon"
                              Data="M8 5V19L19 12L8 5Z"
                              Fill="{StaticResource IconBrush}"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              Visibility="Visible"/>
                        
                        
                        <!-- Pause Icon -->
                        
                        
                        <Path x:Name="PauseIcon"
                              Data="M6 19H10V5H6V19ZM14 5V19H18V5H14Z"
                              Fill="{StaticResource IconBrush}"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>
                    
                    </Grid>
                
                </Button>
                
                
                <!-- Stop Button -->
                
                
                <Button Style="{StaticResource ControlButtonStyle}"
                        Margin="16,0,0,0"
                        Click="StopButton_Click">
                    
                    
                    <Path Data="M6 6H18V18H6V6Z"
                          Fill="{StaticResource IconBrush}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"/>
                
                </Button>
                
                
                <!-- Mute Toggle Button -->
                
                
                <Button x:Name="MuteButton"
                        Style="{StaticResource ControlButtonStyle}"
                        Margin="16,0,0,0"
                        Click="MuteButton_Click">
                    
                    
                    <Grid>
                        
                        
                        <!-- Muted Icon -->
                        
                        
                        <Path x:Name="MutedIcon"
                              Data="M11 5L6 9H2V15H6L11 19V5ZM16 12C16 10.5 15.2 9.2 14 8.4V15.5C15.2 14.8 16 13.5 16 12Z"
                              Fill="{StaticResource IconBrush}"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>
                        
                        
                        <!-- Unmuted Icon -->
                        
                        
                        <Path x:Name="UnmutedIcon"
                              Data="M3 9V15H7L12 20V4L7 9H3ZM16 12C16 13.66 15.17 15.13 13.93 16.02L15.35 17.44C17.22 16.05 18.5 13.77 18.5 11.99C18.5 10.21 17.22 7.94 15.35 6.55L13.93 7.97C15.17 8.85 16 10.33 16 12Z"
                              Fill="{StaticResource IconBrush}"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              Visibility="Visible"/>
                    
                    </Grid>
                
                </Button>
            
            </StackPanel>            
            <!-- Total Time -->
            
            
            <TextBlock Grid.Column="2"
                      x:Name="TotalTimeText"
                      Text="0:00"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      FontSize="12"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      Margin="16,0">
            </TextBlock>
        
        </Grid>
    

    </Grid>
</Window>
