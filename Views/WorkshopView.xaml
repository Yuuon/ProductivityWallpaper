<UserControl x:Class="ProductivityWallpaper.Views.WorkshopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">

    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel - Search and Grid -->
        <Grid Grid.Column="0" Margin="42,24,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Search and Filter Bar -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Search Box -->
                <Border Grid.Column="0" 
                        Background="{StaticResource BackgroundBlockBrush}"
                        BorderBrush="{StaticResource BorderLineBrush}"
                        BorderThickness="1"
                        CornerRadius="15"
                        Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 CaretBrush="{StaticResource TextPrimaryBrush}"
                                 FontSize="14"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 Tag="{DynamicResource Workshop_SearchPlaceholder}"/>
                        <Path Grid.Column="1" 
                              Margin="0,0,12,0"
                              Width="18" Height="18"
                              Data="M8 16C12.4183 16 16 12.4183 16 8C16 3.58172 12.4183 0 8 0C3.58172 0 0 3.58172 0 8C0 12.4183 3.58172 16 8 16Z M18 18L13.65 13.65"
                              Stroke="{StaticResource IconBrush}"
                              StrokeThickness="2.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Grid>
                </Border>
                
                <!-- Resolution Filter -->
                <Border Grid.Column="1"
                        Background="{StaticResource BackgroundBlockBrush}"
                        BorderBrush="{StaticResource BorderLineBrush}"
                        BorderThickness="1"
                        CornerRadius="15"
                        Height="40"
                        Width="144"
                        Margin="16,0,0,0">
                    <Grid>
                        <ComboBox ItemsSource="{Binding Resolutions}"
                                  SelectedItem="{Binding SelectedResolution}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Padding="12,0"
                                  VerticalContentAlignment="Center"/>
                        <Path HorizontalAlignment="Right"
                              Margin="0,0,12,0"
                              Width="12" Height="7"
                              Data="M6.56836 6.35274C6.40078 6.52031 6.17344 6.675 5.95898 6.62813C5.74336 6.66445 5.54063 6.49688 5.37305 6.35273L0.196875 1.15313C-0.065625 0.890625 -0.065625 0.459375 0.196875 0.196875C0.459375 -0.065625 0.890625 -0.065625 1.15313 0.196875L5.9707 5.1457L10.8 0.196875C11.0625 -0.065625 11.4938 -0.065625 11.7563 0.196875C12.0188 0.459375 12.0188 0.890625 11.7563 1.15313L6.56836 6.35274Z"
                              Fill="{StaticResource IconBrush}"/>
                    </Grid>
                </Border>
                
                <!-- Sort Filter -->
                <Border Grid.Column="2"
                        Background="{StaticResource BackgroundBlockBrush}"
                        BorderBrush="{StaticResource BorderLineBrush}"
                        BorderThickness="1"
                        CornerRadius="15"
                        Height="40"
                        Width="128"
                        Margin="16,0,0,0">
                    <Grid>
                        <ComboBox ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Padding="12,0"
                                  VerticalContentAlignment="Center"/>
                        <Path HorizontalAlignment="Right"
                              Margin="0,0,12,0"
                              Width="12" Height="7"
                              Data="M6.56836 6.35274C6.40078 6.52031 6.17344 6.675 5.95898 6.62813C5.74336 6.66445 5.54063 6.49688 5.37305 6.35273L0.196875 1.15313C-0.065625 0.890625 -0.065625 0.459375 0.196875 0.196875C0.459375 -0.065625 0.890625 -0.065625 1.15313 0.196875L5.9707 5.1457L10.8 0.196875C11.0625 -0.065625 11.4938 -0.065625 11.7563 0.196875C12.0188 0.459375 12.0188 0.890625 11.7563 1.15313L6.56836 6.35274Z"
                              Fill="{StaticResource IconBrush}"/>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Theme Cards Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ThemeItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ThemeCardStyle}"
                                    Margin="0,0,16,16"
                                    MouseLeftButtonDown="OnThemeCardClick">
                                <Grid>
                                    <!-- Thumbnail -->
                                    <Image Source="{Binding Thumbnail}" 
                                           Stretch="UniformToFill"
                                           ClipToBounds="True">
                                        <Image.Clip>
                                            <RectangleGeometry Rect="0,0,316,178" RadiusX="10" RadiusY="10"/>
                                        </Image.Clip>
                                    </Image>
                                    <!-- Type Badge -->
                                    <Border VerticalAlignment="Top" 
                                            HorizontalAlignment="Right"
                                            Background="#AA000000"
                                            CornerRadius="0,10,0,4"
                                            Padding="8,4"
                                            Margin="4">
                                        <TextBlock Text="{Binding Type}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        
        <!-- Separator Line -->
        <Line Grid.Column="0"
              HorizontalAlignment="Right"
              Y1="0" Y2="1"
              Stretch="UniformToFill"
              Stroke="{StaticResource BorderLineBrush}"
              StrokeThickness="1"/>
        
        <!-- Right Panel - Details -->
        <Grid Grid.Column="1" Margin="24,24,42,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Scroll Indicator -->
            <Border Grid.Row="0"
                    Width="8" 
                    Height="566"
                    Background="{StaticResource IconBrush}"
                    CornerRadius="4"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,24"
                    Visibility="Collapsed"/>
            
            <!-- Selected Theme Details -->
            <ScrollViewer Grid.Row="0" Grid.RowSpan="2" 
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Visibility="{Binding HasSelectedTheme, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!-- Preview Image -->
                    <Border Style="{StaticResource ThemeCardStyle}"
                            Margin="0,0,0,16">
                        <Image Source="{Binding SelectedTheme.Thumbnail}" 
                               Stretch="UniformToFill"
                               ClipToBounds="True">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,316,178" RadiusX="10" RadiusY="10"/>
                            </Image.Clip>
                        </Image>
                    </Border>
                    
                    <!-- Theme Name -->
                    <TextBlock Text="{Binding SelectedTheme.Name}"
                               Style="{StaticResource SubHeaderTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,4"/>
                    
                    <!-- Author -->
                    <TextBlock Text="{Binding SelectedTheme.Author}"
                               Style="{StaticResource CaptionTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    
                    <!-- File Size and Resolution -->
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Run Text="{Binding SelectedTheme.FileSize, StringFormat='{}{0:F1} MB'}" 
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Run Text=" / " 
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Run Text="{Binding SelectedTheme.Resolution}" 
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    </TextBlock>
                    
                    <!-- Tags -->
                    <ItemsControl ItemsSource="{Binding SelectedTheme.Tags}"
                                  Margin="0,0,0,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected}"
                                              Style="{StaticResource TagButtonStyle}"
                                              Margin="0,0,8,8"
                                              Checked="OnTagChecked"
                                              Unchecked="OnTagUnchecked"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Use Now Button -->
                    <Button Content="{DynamicResource Workshop_UseNow}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding UseThemeCommand}"
                            Height="44"
                            Margin="0,0,0,12"/>
                    
                    <!-- Edit Button -->
                    <Button Content="{DynamicResource Workshop_Edit}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding EditThemeCommand}"
                            Height="44"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Empty State -->
            <StackPanel Grid.Row="0" Grid.RowSpan="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedTheme, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="{DynamicResource Workshop_SelectThemeHint}"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
