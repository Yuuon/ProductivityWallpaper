<UserControl x:Class="ProductivityWallpaper.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="42,30">
        <!-- Language Setting -->
        <TextBlock Text="{DynamicResource Label_Language}" 
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   FontSize="16" 
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>
        <ComboBox ItemsSource="{Binding Languages}" 
                  SelectedItem="{Binding SelectedLanguage}" 
                  Width="200" 
                  HorizontalAlignment="Left"
                  Style="{StaticResource {x:Type ComboBox}}"
                  Background="{StaticResource BackgroundBlockBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderBrush="{StaticResource BorderLineBrush}"/>
        
        <!-- Separator -->
        <Border Height="1" 
                Background="{StaticResource BorderLineBrush}" 
                Margin="0,30"/>
        
        <!-- Media Library Setting -->
        <TextBlock Text="{DynamicResource Settings_MediaLibraryPath}" 
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   FontSize="16" 
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding MediaLibraryPath, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchBoxStyle}"
                     VerticalContentAlignment="Center"
                     Margin="0,0,12,0"/>
            <Button Grid.Column="1"
                    Content="{DynamicResource Settings_Browse}"
                    Command="{Binding BrowseMediaLibraryCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="80"/>
        </Grid>
    </StackPanel>
</UserControl>