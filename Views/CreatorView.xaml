<UserControl x:Class="ProductivityWallpaper.Views.CreatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ProductivityWallpaper.ViewModels"
             xmlns:models="clr-namespace:ProductivityWallpaper.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:CreatorViewModel}">

    <UserControl.Resources>
        <!-- Scheme Item Template for Submenu -->
        <DataTemplate x:Key="SchemeItemTemplate" DataType="{x:Type models:SchemeModel}">
            <Button Command="{Binding DataContext.SelectSchemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="12,8"
                    HorizontalContentAlignment="Stretch">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BackgroundSelectedBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="{Binding Name}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    
                    <!-- Active Indicator Checkmark -->
                    <Path Grid.Column="1"
                           Data="M4.5 8.5L7 11L11.5 6.5"
                           Stroke="{StaticResource AccentBrush}"
                           StrokeThickness="2"
                           Width="16"
                           Height="16"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Button>
        </DataTemplate>

        <!-- New Scheme Button Style -->
        <Style x:Key="NewSchemeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Feature Expander Toggle Button Style -->
        <Style x:Key="FeatureExpanderButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundSelectedBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundMainBrush}"
          MouseDown="CreatorView_MouseDown">
        
        <!-- Welcome Page -->
        <Grid Visibility="{Binding IsWelcomePage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600">
                <!-- Welcome Text -->
                <TextBlock Text="{DynamicResource Creator_WelcomeTitle}"
                           Style="{StaticResource HeaderTextStyle}"
                           TextAlignment="Center"
                           Margin="0,0,0,32"/>
                
                <!-- Theme Name Input with Centered Placeholder -->
                <Border Background="{StaticResource BackgroundBlockBrush}"
                        BorderBrush="{StaticResource BorderLineBrush}"
                        BorderThickness="1"
                        CornerRadius="15"
                        Height="40"
                        Margin="0,0,0,24">
                    <Grid>
                        <!-- Placeholder Text (shown when input is empty) -->
                        <TextBlock Text="{DynamicResource Creator_ThemeNamePlaceholder}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding NewThemeName, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        <!-- Actual Input -->
                        <TextBox Text="{Binding NewThemeName, UpdateSourceTrigger=PropertyChanged}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  CaretBrush="{StaticResource TextPrimaryBrush}"
                                  FontSize="14"
                                  Padding="16,0"
                                  VerticalContentAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  TextAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Create Button -->
                <Button Content="{DynamicResource Creator_CreateTheme}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartCreatingCommand}"
                        Width="200"
                        Height="44"/>
            </StackPanel>
        </Grid>
        
        <!-- Creating Page -->
        <Grid Visibility="{Binding IsCreatingPage, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="242"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Sidebar -->
            <Grid Grid.Column="0" Background="{StaticResource BackgroundBlockBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Back Button (Fixed at top, outside scroll) -->
                <Button Grid.Row="0"
                        Command="{Binding BackToWelcomeCommand}"
                        Margin="16,16,16,8"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 4L4 12L12 20 M6 12H20"
                              Stroke="{StaticResource IconBrush}"
                              StrokeThickness="2"
                              Width="16" Height="16"
                              Stretch="Uniform"/>
                        <TextBlock Text="{DynamicResource Creator_Back}"
                                   Foreground="{StaticResource IconBrush}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Scrollable Navigation Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,8,16,16">
                        
                        <!-- Theme Preview (Simple Button) -->
                        <Button Command="{Binding SelectFeatureCommand}"
                                CommandParameter="ThemePreview"
                                Style="{Binding IsThemePreviewSelected, Converter={StaticResource BooleanToFeatureButtonConverter}}">
                            <Grid>
                                <TextBlock Text="{DynamicResource Creator_Feature_ThemePreview}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        
                        <!-- Desktop Background (Expandable) -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Feature Header Button -->
                                <ToggleButton Style="{StaticResource FeatureExpanderButtonStyle}"
                                             IsChecked="{Binding IsDesktopBackgroundExpanded, Mode=TwoWay}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Creator_Feature_DesktopBackground}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DesktopBackgroundSchemes.Count, StringFormat='({0})'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding DesktopBackgroundSchemes.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <!-- Expand/Collapse Arrow -->
                                        <Path Grid.Column="2"
                                              Data="M6 9L12 15L18 9"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="2"
                                              Width="16"
                                              Height="16"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDesktopBackgroundExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="180" CenterX="8" CenterY="8"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </ToggleButton>
                                
                                <!-- Expanded Submenu -->
                                <Border Visibility="{Binding IsDesktopBackgroundExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Background="{StaticResource BackgroundBlockBrush}"
                                        BorderThickness="0">
                                    <StackPanel Margin="8,4,0,0">
                                        <ItemsControl ItemsSource="{Binding DesktopBackgroundSchemes}"
                                                      ItemTemplate="{StaticResource SchemeItemTemplate}"/>
                                        
                                        <Button Content="{DynamicResource Creator_NewScheme}"
                                                Command="{Binding CreateNewSchemeCommand}"
                                                CommandParameter="{x:Static models:FeatureType.DesktopBackground}"
                                                Style="{StaticResource NewSchemeButtonStyle}"
                                                Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Mouse Click (Expandable) -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <ToggleButton Style="{StaticResource FeatureExpanderButtonStyle}"
                                             IsChecked="{Binding IsMouseClickExpanded, Mode=TwoWay}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Creator_Feature_MouseClick}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            
                                            <TextBlock Text="{Binding MouseClickSchemes.Count, StringFormat='({0})'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding MouseClickSchemes.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <Path Grid.Column="2"
                                              Data="M6 9L12 15L18 9"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="2"
                                              Width="16"
                                              Height="16"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseClickExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="180" CenterX="8" CenterY="8"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </ToggleButton>
                                
                                <Border Visibility="{Binding IsMouseClickExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Background="{StaticResource BackgroundBlockBrush}"
                                        BorderThickness="0">
                                    <StackPanel Margin="8,4,0,0">
                                        <ItemsControl ItemsSource="{Binding MouseClickSchemes}"
                                                      ItemTemplate="{StaticResource SchemeItemTemplate}"/>
                                        
                                        <Button Content="{DynamicResource Creator_NewScheme}"
                                                Command="{Binding CreateNewSchemeCommand}"
                                                CommandParameter="{x:Static models:FeatureType.MouseClick}"
                                                Style="{StaticResource NewSchemeButtonStyle}"
                                                Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Shutdown (Expandable) -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <ToggleButton Style="{StaticResource FeatureExpanderButtonStyle}"
                                             IsChecked="{Binding IsShutdownExpanded, Mode=TwoWay}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Creator_Feature_Shutdown}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            
                                            <TextBlock Text="{Binding ShutdownSchemes.Count, StringFormat='({0})'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding ShutdownSchemes.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <Path Grid.Column="2"
                                              Data="M6 9L12 15L18 9"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="2"
                                              Width="16"
                                              Height="16"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsShutdownExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="180" CenterX="8" CenterY="8"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </ToggleButton>
                                
                                <Border Visibility="{Binding IsShutdownExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Background="{StaticResource BackgroundBlockBrush}"
                                        BorderThickness="0">
                                    <StackPanel Margin="8,4,0,0">
                                        <ItemsControl ItemsSource="{Binding ShutdownSchemes}"
                                                      ItemTemplate="{StaticResource SchemeItemTemplate}"/>
                                        
                                        <Button Content="{DynamicResource Creator_NewScheme}"
                                                Command="{Binding CreateNewSchemeCommand}"
                                                CommandParameter="{x:Static models:FeatureType.Shutdown}"
                                                Style="{StaticResource NewSchemeButtonStyle}"
                                                Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Boot/Restart (Expandable) -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <ToggleButton Style="{StaticResource FeatureExpanderButtonStyle}"
                                             IsChecked="{Binding IsBootRestartExpanded, Mode=TwoWay}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Creator_Feature_BootRestart}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            
                                            <TextBlock Text="{Binding BootRestartSchemes.Count, StringFormat='({0})'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding BootRestartSchemes.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <Path Grid.Column="2"
                                              Data="M6 9L12 15L18 9"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="2"
                                              Width="16"
                                              Height="16"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBootRestartExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="180" CenterX="8" CenterY="8"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </ToggleButton>
                                
                                <Border Visibility="{Binding IsBootRestartExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Background="{StaticResource BackgroundBlockBrush}"
                                        BorderThickness="0">
                                    <StackPanel Margin="8,4,0,0">
                                        <ItemsControl ItemsSource="{Binding BootRestartSchemes}"
                                                      ItemTemplate="{StaticResource SchemeItemTemplate}"/>
                                        
                                        <Button Content="{DynamicResource Creator_NewScheme}"
                                                Command="{Binding CreateNewSchemeCommand}"
                                                CommandParameter="{x:Static models:FeatureType.BootRestart}"
                                                Style="{StaticResource NewSchemeButtonStyle}"
                                                Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Screen Wake (Expandable) -->
                        <Border Margin="0,8,0,0">
                            <StackPanel>
                                <ToggleButton Style="{StaticResource FeatureExpanderButtonStyle}"
                                             IsChecked="{Binding IsScreenWakeExpanded, Mode=TwoWay}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Creator_Feature_ScreenWake}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                            
                                            <TextBlock Text="{Binding ScreenWakeSchemes.Count, StringFormat='({0})'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding ScreenWakeSchemes.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        </StackPanel>
                                        
                                        <Path Grid.Column="2"
                                              Data="M6 9L12 15L18 9"
                                              Stroke="{StaticResource TextSecondaryBrush}"
                                              StrokeThickness="2"
                                              Width="16"
                                              Height="16"
                                              Stretch="Uniform"
                                              VerticalAlignment="Center">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsScreenWakeExpanded}" Value="True">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="180" CenterX="8" CenterY="8"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Grid>
                                </ToggleButton>
                                
                                <Border Visibility="{Binding IsScreenWakeExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Background="{StaticResource BackgroundBlockBrush}"
                                        BorderThickness="0">
                                    <StackPanel Margin="8,4,0,0">
                                        <ItemsControl ItemsSource="{Binding ScreenWakeSchemes}"
                                                      ItemTemplate="{StaticResource SchemeItemTemplate}"/>
                                        
                                        <Button Content="{DynamicResource Creator_NewScheme}"
                                                Command="{Binding CreateNewSchemeCommand}"
                                                CommandParameter="{x:Static models:FeatureType.ScreenWake}"
                                                Style="{StaticResource NewSchemeButtonStyle}"
                                                Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Open App (Simple Button) -->
                        <Button Command="{Binding SelectFeatureCommand}"
                                CommandParameter="OpenApp"
                                Style="{Binding IsOpenAppSelected, Converter={StaticResource BooleanToFeatureButtonConverter}}"
                                Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="{DynamicResource Creator_Feature_OpenApp}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        
                        <!-- Desktop Clock (Simple Button) -->
                        <Button Command="{Binding SelectFeatureCommand}"
                                CommandParameter="DesktopClock"
                                Style="{Binding IsDesktopClockSelected, Converter={StaticResource BooleanToFeatureButtonConverter}}"
                                Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="{DynamicResource Creator_Feature_DesktopClock}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        
                        <!-- Pomodoro (Simple Button) -->
                        <Button Command="{Binding SelectFeatureCommand}"
                                CommandParameter="Pomodoro"
                                Style="{Binding IsPomodoroSelected, Converter={StaticResource BooleanToFeatureButtonConverter}}"
                                Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="{DynamicResource Creator_Feature_Pomodoro}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        
                        <!-- Anniversary (Simple Button) -->
                        <Button Command="{Binding SelectFeatureCommand}"
                                CommandParameter="Anniversary"
                                Style="{Binding IsAnniversarySelected, Converter={StaticResource BooleanToFeatureButtonConverter}}"
                                Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="{DynamicResource Creator_Feature_Anniversary}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            
            <!-- Right Content Area (Unchanged) -->
            <Grid Grid.Column="1" Margin="32,24,42,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Theme Name Header (Left Aligned) -->
                <Grid Grid.Row="0" 
                      HorizontalAlignment="Left"
                      Height="32"
                      Margin="0,0,0,24">
                    <!-- Display Mode -->
                    <StackPanel Orientation="Horizontal" 
                                VerticalAlignment="Center"
                                Visibility="{Binding IsEditingThemeName, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding CurrentThemeName}"
                                   Style="{StaticResource SubHeaderTextStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        
                        <Button Command="{Binding ToggleEditThemeNameCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8"
                                Cursor="Hand"
                                Width="32"
                                Height="32"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Width="{TemplateBinding Width}"
                                                        Height="{TemplateBinding Height}">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Path Data="M525 148.414H531M528 137.414C528.265 137.149 528.625 137 529 137C529.186 137 529.37 137.037 529.541 137.108C529.713 137.179 529.869 137.283 530 137.414C530.131 137.546 530.235 137.701 530.307 137.873C530.378 138.045 530.414 138.228 530.414 138.414C530.414 138.6 530.378 138.784 530.307 138.955C530.235 139.127 530.131 139.283 530 139.414L521.667 147.748L519 148.414L519.667 145.748L528 137.414Z"
                                  Stroke="{StaticResource IconBrush}"
                                  StrokeThickness="1.6"
                                  Width="16" Height="16"
                                  Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                    
                    <!-- Edit Mode -->
                    <TextBox x:Name="ThemeNameTextBox"
                             Text="{Binding CurrentThemeName, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             CaretBrush="{StaticResource TextPrimaryBrush}"
                             MinWidth="200"
                             MaxWidth="400"
                             Height="32"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center"
                             Visibility="{Binding IsEditingThemeName, Converter={StaticResource BooleanToVisibilityConverter}}"
                             LostFocus="ThemeNameTextBox_LostFocus"
                             KeyDown="ThemeNameTextBox_KeyDown"/>
                </Grid>
                
                <!-- Feature Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Preview -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BackgroundBlockBrush}"
                            BorderBrush="{StaticResource BorderLineBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Margin="0,0,16,0">
                        <Grid>
                            <!-- Empty State -->
                            <StackPanel VerticalAlignment="Center" 
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasPreviewContent, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
