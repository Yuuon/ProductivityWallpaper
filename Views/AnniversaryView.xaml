<UserControl x:Class="ProductivityWallpaper.Views.AnniversaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ProductivityWallpaper.ViewModels"
             xmlns:models="clr-namespace:ProductivityWallpaper.Models"
             xmlns:controls="clr-namespace:ProductivityWallpaper.Views.Controls"
             xmlns:converters="clr-namespace:ProductivityWallpaper.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:AnniversaryViewModel}">
    
    <UserControl.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Inverse Boolean to Visibility Converter -->
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        
        <!-- Anniversary Style Card Style -->
        <Style x:Key="AnniversaryStyleCardStyle" TargetType="Border">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBlockBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Accent1Brush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryGradientBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- Anniversary Item Card Style -->
        <Style x:Key="AnniversaryItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundBlockBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Delete Button Style -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Edit Button Style -->
        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- ComboBox Style for Repeat Mode -->
        <Style x:Key="RepeatModeComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Width" Value="120"/>
        </Style>
        
        <!-- Add Button Style -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="{StaticResource BackgroundBlockBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Accent1Brush}"/>
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Title Bar -->
            <RowDefinition Height="*"/>          <!-- Content -->
        </Grid.RowDefinitions>
        
        <!-- Section 1: Editable Title Bar -->
        <Grid Grid.Row="0" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Scheme Name (Display Mode) -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsEditingName, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding SchemeName}"
                          Style="{StaticResource SubHeaderTextStyle}"
                          VerticalAlignment="Center"/>
                
                <!-- Edit Button -->
                <Button Command="{Binding ToggleEditNameCommand}"
                        Style="{StaticResource EditButtonStyle}"
                        Margin="8,0,0,0">
                    <Path Data="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                          Stroke="{StaticResource IconBrush}"
                          StrokeThickness="2"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>
            </StackPanel>
            
            <!-- Scheme Name (Edit Mode) -->
            <TextBox Grid.Column="0"
                     Text="{Binding SchemeName, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     CaretBrush="{StaticResource TextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     MinWidth="200"
                     MaxWidth="400"
                     Height="32"
                     VerticalAlignment="Center"
                     VerticalContentAlignment="Center"
                     Visibility="{Binding IsEditingName, Converter={StaticResource BooleanToVisibilityConverter}}"
                     LostFocus="SchemeNameTextBox_LostFocus"
                     KeyDown="SchemeNameTextBox_KeyDown">
                <TextBox.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            
            <!-- Activate Button -->
            <Button Grid.Column="1"
                    Content="{Binding IsActive, Converter={StaticResource BooleanToActiveTextConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ActivateSchemeCommand}"
                    IsEnabled="{Binding IsActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Padding="16,8"
                    Height="36"
                    Visibility="{Binding HasAnniversaries, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
        
        <!-- Content Area -->
        <Border Grid.Row="1"
                Margin="24,8,24,24">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    
                    <!-- Section 2: Display Style Selection -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Desktop Display Style"
                                  Style="{StaticResource SubHeaderTextStyle}"
                                  Margin="0,0,0,16"/>
                        
                        <StackPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding DisplayStyles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:AnniversaryStyleModel}">
                                        <Button Command="{Binding DataContext.ToggleStyleActivationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Margin="0,0,12,0">
                                            
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <ContentPresenter/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            
                                            <Border Style="{StaticResource AnniversaryStyleCardStyle}">
                                                <Grid>
                                                    
                                                    <!-- Preview Image -->
                                                    <Image Source="{Binding PreviewImagePath, Converter={StaticResource StringToImageSourceConverter}}"
                                                          Stretch="UniformToFill"
                                                          Margin="4"
                                                          Opacity="0.5">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PreviewImagePath}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    
                                                    <!-- Style Name -->
                                                    <TextBlock Text="{Binding Name}"
                                                              Foreground="{StaticResource TextPrimaryBrush}"
                                                              FontSize="12"
                                                              FontWeight="SemiBold"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    
                                                    <!-- Active Indicator -->
                                                    <Border Background="{StaticResource PrimaryGradientBrush}"
                                                            CornerRadius="8"
                                                            Width="16"
                                                            Height="16"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="4"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Path Data="M5 13l4 4L19 7"
                                                              Stroke="White"
                                                              StrokeThickness="2"
                                                              Width="10"
                                                              Height="10"
                                                              Stretch="Uniform"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    
                    
                    <!-- Section 3: Anniversaries List -->
                    <StackPanel>
                        
                        <TextBlock Text="Anniversaries"
                                  Style="{StaticResource SubHeaderTextStyle}"
                                  Margin="0,0,0,16"/>
                        
                        
                        <!-- Empty State -->
                        
                        <Border Background="{StaticResource BackgroundBlockBrush}"
                                BorderBrush="{StaticResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="48"
                                MinHeight="200"
                                Visibility="{Binding HasAnniversaries, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                
                                <Path Data="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                      Stroke="{StaticResource IconBrush}"
                                      StrokeThickness="2"
                                      Width="48"
                                      Height="48"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,16"/>
                                
                                <TextBlock Text="No anniversaries yet"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="16"
                                          TextAlignment="Center"
                                          Margin="0,0,0,8"/>
                                
                                
                                <TextBlock Text="Click the button below to add your first anniversary"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="13"
                                          TextAlignment="Center"/>
                            
                            </StackPanel>
                        
                        </Border>
                        
                        
                        <!-- Anniversary Items List -->
                        
                        <ItemsControl ItemsSource="{Binding Anniversaries}"
                                      Visibility="{Binding HasAnniversaries, Converter={StaticResource BooleanToVisibilityConverter}}">
                            
                            <ItemsControl.ItemTemplate>
                                
                                <DataTemplate DataType="{x:Type models:AnniversaryEventModel}">
                                    
                                    <Border Style="{StaticResource AnniversaryItemCardStyle}">
                                        
                                        <Grid>
                                            
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            
                                            <!-- Row 1: Name and Delete -->
                                            
                                            <Grid Grid.Row="0">
                                                
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                
                                                <!-- Name Display -->
                                                
                                                <StackPanel Grid.Column="0"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsNameEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                    
                                                    <TextBlock Text="{Binding Name}"
                                                              Foreground="{StaticResource TextPrimaryBrush}"
                                                              FontSize="16"
                                                              FontWeight="SemiBold"
                                                              VerticalAlignment="Center"/>
                                                    
                                                    
                                                    <Button Command="{Binding DataContext.StartEditNameCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource EditButtonStyle}">
                                                        
                                                        <Path Data="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
                                                              Stroke="{StaticResource IconBrush}"
                                                              StrokeThickness="2"
                                                              Width="14"
                                                              Height="14"
                                                              Stretch="Uniform"/>
                                                    
                                                    </Button>
                                                
                                                </StackPanel>
                                                
                                                
                                                <!-- Name Edit -->
                                                
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         FontSize="16"
                                                         FontWeight="SemiBold"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         CaretBrush="{StaticResource TextPrimaryBrush}"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding IsNameEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                         LostFocus="EventNameTextBox_LostFocus"
                                                         KeyDown="EventNameTextBox_KeyDown"
                                                         Tag="{Binding}"/>
                                                
                                                
                                                <!-- Delete Button -->
                                                
                                                <Button Grid.Column="1"
                                                        Command="{Binding DataContext.DeleteAnniversaryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DeleteButtonStyle}">
                                                    
                                                    <Path Data="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                                                          Stroke="#EF5350"
                                                          StrokeThickness="2"
                                                          Width="16"
                                                          Height="16"
                                                          Stretch="Uniform"/>
                                                
                                                </Button>
                                            
                                            </Grid>
                                            
                                            
                                            <!-- Row 2: Configuration -->
                                            
                                            <StackPanel Grid.Row="1"
                                                        Orientation="Horizontal"
                                                        Margin="0,12,0,0">
                                                
                                                <!-- Repeat Mode ComboBox -->
                                                
                                                <ComboBox Style="{StaticResource RepeatModeComboStyle}"
                                                          SelectedItem="{Binding RepeatMode}"
                                                          Margin="0,0,12,0">
                                                    
                                                    <ComboBox.ItemsSource>
                                                        
                                                        <x:Array Type="models:RepeatMode">
                                                            <models:RepeatMode>NoRepeat</models:RepeatMode>
                                                            <models:RepeatMode>Yearly</models:RepeatMode>
                                                            <models:RepeatMode>Monthly</models:RepeatMode>
                                                            <models:RepeatMode>Weekly</models:RepeatMode>
                                                        </x:Array>
                                                    
                                                    </ComboBox.ItemsSource>
                                                
                                                </ComboBox>
                                                
                                                
                                                <!-- Adaptive Date Picker -->
                                                
                                                <controls:AdaptiveDatePicker Mode="{Binding RepeatMode}"
                                                                              Date="{Binding TargetDate}"
                                                                              WeeklyDay="{Binding WeeklyDay}"
                                                                              Margin="0,0,12,0"/>
                                                
                                                
                                                <!-- Days Remaining Indicator -->
                                                
                                                <Border Background="{StaticResource PrimaryGradientBrush}"
                                                        CornerRadius="12"
                                                        Padding="8,4">
                                                    
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                              FontSize="12"
                                                              FontWeight="SemiBold">
                                                        
                                                        <TextBlock.Text>
                                                            
                                                            <MultiBinding StringFormat="{}{0} days left">
                                                                
                                                                <Binding Path="DaysRemaining"/>
                                                            
                                                            </MultiBinding>
                                                        
                                                        </TextBlock.Text>
                                                    
                                                    </TextBlock>
                                                
                                                </Border>
                                            
                                            </StackPanel>
                                        
                                        </Grid>
                                    
                                    </Border>
                                
                                </DataTemplate>
                            
                            </ItemsControl.ItemTemplate>
                        
                        </ItemsControl>
                        
                        
                        <!-- Section 4: Add Button -->
                        
                        <Button Content="+ New Anniversary"
                                Command="{Binding AddAnniversaryCommand}"
                                Style="{StaticResource AddButtonStyle}"
                                Margin="0,16,0,0"/>
                    
                    </StackPanel>
                
                </StackPanel>
            
            </ScrollViewer>
        
        </Border>
    
    </Grid>

</UserControl>
