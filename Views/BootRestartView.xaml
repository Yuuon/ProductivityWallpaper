                                       Fill="#EF5350"
                                       Width="16"
                                       Height="16"
                                       Stretch="Uniform"/>
                             </Button>
                        </StackPanel>
                    </Grid>
                    
                    
                    <!-- Section 3: Image/Video List -->
                    <Border Background="{StaticResource BackgroundBlockBrush}"
                           BorderBrush="{StaticResource BorderLineBrush}"
                           BorderThickness="1"
                           CornerRadius="10"
                           Padding="16"
                           Margin="0,0,0,16">
                        <StackPanel>
                            
                            <!-- Header Row -->
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                          Text="Images/Videos"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalAlignment="Center"/>
                                
                                <ComboBox Grid.Column="1"
                                         Style="{StaticResource PlaybackModeComboStyle}"
                                         Width="100"
                                         SelectedItem="{Binding SelectedPlaybackMode}">
                                    <ComboBox.ItemsSource>
                                        <x:Array Type="models:PlaybackMode">
                                            <models:PlaybackMode>Sequential</models:PlaybackMode>
                                            <models:PlaybackMode>Random</models:PlaybackMode>
                                        </x:Array>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </Grid>
                            
                            
                            <!-- Media Items List -->
                            
                            <ListView Style="{StaticResource MediaListViewStyle}"
                                     ItemContainerStyle="{StaticResource MediaListViewItemStyle}"
                                     ItemTemplate="{StaticResource MediaItemTemplate}"
                                     ItemsSource="{Binding ImageVideoItems}"
                                     MaxHeight="300">
                            </ListView>
                        </StackPanel>
                    </Border>
                    
                    
                    <!-- Section 4: Audio List -->
                    
                    <Border Background="{StaticResource BackgroundBlockBrush}"
                           BorderBrush="{StaticResource BorderLineBrush}"
                           BorderThickness="1"
                           CornerRadius="10"
                           Padding="16">
                        
                        <StackPanel>
                            
                            
                            <!-- Header Row -->
                            
                            
                            <Grid Margin="0,0,0,12">
                                
                                <Grid.ColumnDefinitions>
                                    
                                    <ColumnDefinition Width="*"/>
                                    
                                    <ColumnDefinition Width="Auto"/>
                                
                                
                                </Grid.ColumnDefinitions>
                                
                                
                                <TextBlock Grid.Column="0"
                                          Text="Audio"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          VerticalAlignment="Center"/>
                                
                                
                                <ComboBox Grid.Column="1"
                                         Style="{StaticResource PlaybackModeComboStyle}"
                                         Width="100"
                                         SelectedItem="{Binding SelectedAudioPlaybackMode}">
                                    
                                    <ComboBox.ItemsSource>
                                        
                                        <x:Array Type="models:PlaybackMode">
                                            
                                            <models:PlaybackMode>Sequential</models:PlaybackMode>
                                            
                                            <models:PlaybackMode>Random</models:PlaybackMode>
                                        
                                        
                                        </x:Array>
                                    
                                    
                                    </ComboBox.ItemsSource>
                                
                                
                                </ComboBox>
                            
                            
                            
                            </Grid>
                            
                            
                            
                            <!-- Audio Items List -->
                            
                            
                            <ListView Style="{StaticResource MediaListViewStyle}"
                                     ItemContainerStyle="{StaticResource MediaListViewItemStyle}"
                                     ItemTemplate="{StaticResource AudioItemTemplate}"
                                     ItemsSource="{Binding AudioItems}"
                                     MaxHeight="200">
                            
                            </ListView>
                        
                        
                        </StackPanel>
                    
                    
                    </Border>
                
                
                
                </StackPanel>
            
            
            </ScrollViewer>
        
        
        </Border>
    
    
    
    </Grid>
</UserControl>
