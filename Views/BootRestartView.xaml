<UserControl x:Class="ProductivityWallpaper.Views.BootRestartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ProductivityWallpaper.ViewModels"
             xmlns:models="clr-namespace:ProductivityWallpaper.Models"
             xmlns:converters="clr-namespace:ProductivityWallpaper.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BootRestartViewModel}">
    
    <UserControl.Resources>
        <!-- Boolean to Visibility Converter for inverse -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- File Size Formatter -->
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        
        <!-- Media Type to Visibility Converter -->
        <converters:MediaTypeIsVideoConverter x:Key="MediaTypeIsVideoConverter"/>
        
        <!-- ComboBox Style for DisplayMode -->
        <Style x:Key="DisplayModeComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        
        <!-- ComboBox Style for PlaybackMode -->
        <Style x:Key="PlaybackModeComboStyle" TargetType="ComboBox" BasedOn="{StaticResource DisplayModeComboStyle}">
        </Style>
        
        <!-- Media Item ListView Style -->
        <Style x:Key="MediaListViewStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        
        <!-- Media Item ItemContainer Style -->
        <Style x:Key="MediaListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource BackgroundSelectedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Media Item DataTemplate -->
        <DataTemplate x:Key="MediaItemTemplate" DataType="{x:Type models:MediaItemModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>      <!-- Number -->
                    <ColumnDefinition Width="80"/>       <!-- Thumbnail -->
                    <ColumnDefinition Width="60"/>       <!-- Format -->
                    <ColumnDefinition Width="80"/>       <!-- Size -->
                    <ColumnDefinition Width="60"/>       <!-- Duration -->
                    <ColumnDefinition Width="*"/>        <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>      <!-- Controls -->
                </Grid.ColumnDefinitions>
                
                <!-- Number -->
                <TextBlock Grid.Column="0"
                          Text="{Binding OrderIndex, StringFormat='#{0}'}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="12"
                          Width="32"
                          VerticalAlignment="Center"/>
                
                <!-- Thumbnail Container -->
                <Grid Grid.Column="1" Width="64" Height="36">
                    <!-- Image Thumbnail -->
                    <Image Source="{Binding ThumbnailPath}"
                           Stretch="UniformToFill"
                           Visibility="{Binding Type, Converter={StaticResource MediaTypeIsVideoConverter}, ConverterParameter=Invert}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                        <Setter Property="Source" Value="/Resources/Images/default_thumb.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    
                    <!-- Video Thumbnail with Play Overlay -->
                    <Grid Visibility="{Binding Type, Converter={StaticResource MediaTypeIsVideoConverter}}">
                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ThumbnailPath}" Value="">
                                            <Setter Property="Source" Value="/Resources/Images/default_thumb.png"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <!-- Play Button Overlay -->
                        <Path Data="M8 5V19L19 12L8 5Z"
                              Fill="White"
                              Width="20"
                              Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Opacity="0.9">
                            <Path.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="0.5"/>
                            </Path.Effect>
                        </Path>
                    </Grid>
                </Grid>
                
                <!-- Format -->
                <TextBlock Grid.Column="2"
                          Text="{Binding Format}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>
                
                <!-- File Size -->
                <TextBlock Grid.Column="3"
                          Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>
                
                <!-- Duration -->
                <TextBlock Grid.Column="4"
                          Text="{Binding Duration, Converter={StaticResource DurationConverter}}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>
                
                <!-- Controls (Mute, DisplayMode, Remove) -->
                <StackPanel Grid.Column="6"
                           Orientation="Horizontal"
                           HorizontalAlignment="Right">
                    
                    <!-- Mute Toggle Button -->
                    <Button Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            Width="32"
                            Height="32">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <!-- Muted Icon -->
                            <Path Data="M11 5L6 9H2V15H6L11 19V5ZM16 12C16 10.5 15.2 9.2 14 8.4V15.5C15.2 14.8 16 13.5 16 12ZM19 12C19 13.4 18.6 14.7 17.9 15.9L19.3 17.3C20.3 15.7 20.8 13.9 20.8 12C20.8 8.1 18.2 4.8 14.7 3.9V5.7C17.1 6.5 19 9 19 12Z"
                                  Fill="{StaticResource IconBrush}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Visibility="{Binding IsMuted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            
                            <!-- Unmuted Icon -->
                            <Path Data="M3 9V15H7L12 20V4L7 9H3ZM16 12C16 13.66 15.17 15.13 13.93 16.02L15.35 17.44C17.22 16.05 18.5 13.77 18.5 11.99C18.5 10.21 17.22 7.94 15.35 6.55L13.93 7.97C15.17 8.85 16 10.33 16 12Z"
                                  Fill="{StaticResource AccentBrush}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Visibility="{Binding IsMuted, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>
                    
                    <!-- DisplayMode ComboBox (only for images/videos) -->
                    <ComboBox Width="80"
                             Margin="8,0"
                             SelectedItem="{Binding DisplayMode}"
                             IsEnabled="{Binding Type, Converter={StaticResource MediaTypeIsVideoConverter}, ConverterParameter=Invert}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource DisplayModeComboStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static models:MediaFileType.Audio}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemsSource>
                            <x:Array Type="models:DisplayMode">
                                <models:DisplayMode>Fill</models:DisplayMode>
                                <models:DisplayMode>Center</models:DisplayMode>
                                <models:DisplayMode>Tile</models:DisplayMode>
                            </x:Array>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                    
                    <!-- Remove Button -->
                    <Button Command="{Binding DataContext.RemoveMediaCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            Width="32"
                            Height="32">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M18 6L6 18M6 6L18 18"
                              Stroke="{StaticResource IconBrush}"
                              StrokeThickness="2"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>
        
        <!-- Audio Item DataTemplate -->
        <DataTemplate x:Key="AudioItemTemplate" DataType="{x:Type models:MediaItemModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>      <!-- Number -->
                    <ColumnDefinition Width="80"/>       <!-- Thumbnail -->
                    <ColumnDefinition Width="60"/>       <!-- Format -->
                    <ColumnDefinition Width="80"/>       <!-- Size -->
                    <ColumnDefinition Width="60"/>       <!-- Duration -->
                    <ColumnDefinition Width="*"/>        <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>      <!-- Controls -->
                </Grid.ColumnDefinitions>
                
                <!-- Number -->
                <TextBlock Grid.Column="0"
                          Text="{Binding OrderIndex, StringFormat='#{0}'}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="12"
                          Width="32"
                          VerticalAlignment="Center"/>
                
                <!-- Music Icon with Play Overlay -->
                <Grid Grid.Column="1" Width="64" Height="36">
                    <!-- Music Note Icon -->
                    <Path Data="M12 3V13.55C11.41 13.21 10.73 13 10 13C8.34 13 7 14.34 7 16C7 17.66 8.34 19 10 19C11.66 19 13 17.66 13 16V5H18V3H12Z"
                          Fill="{StaticResource IconBrush}"
                          Width="24"
                          Height="24"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                    
                    <!-- Play Button Overlay -->
                    <Path Data="M8 5V19L19 12L8 5Z"
                          Fill="White"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Opacity="0.9"
                          Margin="0,0,4,2">
                        <Path.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="0.5"/>
                        </Path.Effect>
                    </Path>
                </Grid>
                
                <!-- Format -->
                <TextBlock Grid.Column="2"
                          Text="{Binding Format}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>
                
                <!-- File Size -->
                <TextBlock Grid.Column="3"
                          Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>
                
                <!-- Duration -->
                <TextBlock Grid.Column="4"
                          Text="{Binding Duration, Converter={StaticResource DurationConverter}}"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          FontSize="11"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>
                
                <!-- Controls (Mute, Remove) -->
                <StackPanel Grid.Column="6"
                           Orientation="Horizontal"
                           HorizontalAlignment="Right">
                    
                    <!-- Mute Toggle Button -->
                    <Button Command="{Binding DataContext.ToggleMuteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            Width="32"
                            Height="32">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <!-- Muted Icon -->
                            <Path Data="M11 5L6 9H2V15H6L11 19V5ZM16 12C16 10.5 15.2 9.2 14 8.4V15.5C15.2 14.8 16 13.5 16 12ZM19 12C19 13.4 18.6 14.7 17.9 15.9L19.3 17.3C20.3 15.7 20.8 13.9 20.8 12C20.8 8.1 18.2 4.8 14.7 3.9V5.7C17.1 6.5 19 9 19 12Z"
                                  Fill="{StaticResource IconBrush}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Visibility="{Binding IsMuted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            
                            <!-- Unmuted Icon -->
                            <Path Data="M3 9V15H7L12 20V4L7 9H3ZM16 12C16 13.66 15.17 15.13 13.93 16.02L15.35 17.44C17.22 16.05 18.5 13.77 18.5 11.99C18.5 10.21 17.22 7.94 15.35 6.55L13.93 7.97C15.17 8.85 16 10.33 16 12Z"
                                  Fill="{StaticResource AccentBrush}"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Visibility="{Binding IsMuted, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>
                    
                    <!-- Remove Button -->
                    <Button Command="{Binding DataContext.RemoveMediaCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            Width="32"
                            Height="32">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="M18 6L6 18M6 6L18 18"
                              Stroke="{StaticResource IconBrush}"
                              StrokeThickness="2"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Title Bar -->
            <RowDefinition Height="*"/>          <!-- Content (Empty State or Edit State) -->
        </Grid.RowDefinitions>
        
        <!-- Section 1: Editable Title Bar -->
        <Grid Grid.Row="0" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Scheme Name (Display Mode) -->
            <StackPanel Grid.Column="0"
                       Orientation="Horizontal"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsEditingName, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding SchemeName}"
                          Style="{StaticResource SubHeaderTextStyle}"
                          VerticalAlignment="Center"/>
                
                <!-- Edit Button -->
                <Button Command="{Binding ToggleEditNameCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        Margin="8,0,0,0"
                        Width="32"
                        Height="32"
                        VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                Width="{TemplateBinding Width}"
                                                Height="{TemplateBinding Height}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    
                    <!-- Pencil Icon -->
                    <Path Data="M525 148.414H531M528 137.414C528.265 137.149 528.625 137 529 137C529.186 137 529.37 137.037 529.541 137.108C529.713 137.179 529.869 137.283 530 137.414C530.131 137.546 530.235 137.701 530.307 137.873C530.378 138.045 530.414 138.228 530.414 138.414C530.414 138.6 530.378 138.784 530.307 138.955C530.235 139.127 530.131 139.283 530 139.414L521.667 147.748L519 148.414L519.667 145.748L528 137.414Z"
                          Stroke="{StaticResource IconBrush}"
                          StrokeThickness="1.6"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>
            </StackPanel>
            
            <!-- Scheme Name (Edit Mode) -->
            <TextBox Grid.Column="0"
                    Text="{Binding SchemeName, UpdateSourceTrigger=PropertyChanged}"
                    Background="Transparent"
                    BorderThickness="0"
                    CaretBrush="{StaticResource TextPrimaryBrush}"
                    MinWidth="200"
                    MaxWidth="400"
                    Height="32"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Visibility="{Binding IsEditingName, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBox.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            
            <!-- Activate Button -->
            <Button Grid.Column="1"
                    Content="{Binding IsActive, Converter={StaticResource BooleanToActiveTextConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ActivateSchemeCommand}"
                    IsEnabled="{Binding IsActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    Padding="16,8"
                    Height="36"
                    Visibility="{Binding HasContent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
        
        <!-- Empty State -->
        <Border Grid.Row="1"
               Visibility="{Binding HasContent, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
               Margin="24,8,24,24">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                <StackPanel VerticalAlignment="Top">
                    
                    <!-- Section 2: Import Header -->
                    <TextBlock Text="Configure Boot/Restart Media"
                              Style="{StaticResource SubHeaderTextStyle}"
                              Margin="0,0,0,16"/>
                    
                    
                    <!-- Section 3: Supported Formats Info -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Supported formats: JPG, PNG, WebP, BMP, HEIC, SVG, GIF, APNG, MP4, MOV, WebM"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,0,0,4"/>
                        
                        <TextBlock Text="Max file size: 500MB"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="13"
                                  Margin="0,0,0,4"/>
                        
                        <TextBlock Text="Max resolution: 8K (7600x4320)"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="13"/>
                    </StackPanel>
                    
                    
                    <!-- Section 4: Upload Area -->
                    <Border Background="{StaticResource BackgroundBlockBrush}"
                           BorderBrush="{StaticResource BorderLineBrush}"
                           BorderThickness="1"
                           CornerRadius="10"
                           Padding="48"
                           MinHeight="280">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Button Command="{Binding ImportMediaCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            
                            <StackPanel HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <!-- Upload Icon -->
                                <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14C0 17.31 2.69 20 6 20H19C21.76 20 24 17.76 24 15C24 12.36 21.95 10.22 19.35 10.04ZM14 13V17H10V13H7L12 8L17 13H14Z"
                                      Fill="{StaticResource IconBrush}"
                                      Width="64"
                                      Height="64"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,24"/>
                                
                                <TextBlock Text="Click to Import"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          TextAlignment="Center"
                                          Margin="0,0,0,8"/>
                                
                                <TextBlock Text="or drag and drop files here"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="13"
                                          TextAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Edit State -->
        <Border Grid.Row="1"
               Visibility="{Binding HasContent, Converter={StaticResource BooleanToVisibilityConverter}}"
               Margin="24,8,24,24">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    
                    <!-- Section 2: Action Bar -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Title -->
                        <TextBlock Grid.Column="0"
                                  Text="Edit Files"
                                  Style="{StaticResource SubHeaderTextStyle}"
                                  VerticalAlignment="Center"/>
                        
                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="1"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Right">
                            
                             <!-- Continue Import Button -->
                             <Button Command="{Binding ImportMediaCommand}"
                                     Background="{StaticResource BackgroundBlockBrush}"
                                     BorderBrush="{StaticResource BorderLineBrush}"
                                     BorderThickness="1"
                                     Width="36"
                                     Height="36"
                                     Margin="0,0,8,0">
                                 <Button.Style>
                                     <Style TargetType="Button">
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border Background="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             BorderThickness="{TemplateBinding BorderThickness}"
                                                             CornerRadius="18"
                                                             Width="{TemplateBinding Width}"
                                                             Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                         <Style.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                 <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                             </Trigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                                 
                                 <Path Data="M12 5V19M5 12H19"
                                       Stroke="{StaticResource IconBrush}"
                                       StrokeThickness="2"
                                       Width="16"
                                       Height="16"
                                       Stretch="Uniform"/>
                             </Button>
                             
                             <!-- Preview Button -->
                             <Button Command="{Binding PreviewMediaCommand}"
                                     Background="{StaticResource BackgroundBlockBrush}"
                                     BorderBrush="{StaticResource BorderLineBrush}"
                                     BorderThickness="1"
                                     Width="36"
                                     Height="36"
                                     Margin="0,0,8,0">
                                 <Button.Style>
                                     <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border Background="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             BorderThickness="{TemplateBinding BorderThickness}"
                                                             CornerRadius="18"
                                                             Width="{TemplateBinding Width}"
                                                             Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                         <Style.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                 <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                             </Trigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                                 
                                 <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12C2.73 16.39 7 19.5 12 19.5C17 19.5 21.27 16.39 23 12C21.27 7.61 17 4.5 12 4.5ZM12 17C9.24 17 7 14.76 7 12C7 9.24 9.24 7 12 7C14.76 7 17 9.24 17 12C17 14.76 14.76 17 12 17ZM12 9C10.34 9 9 10.34 9 12C9 13.66 10.34 15 12 15C13.66 15 15 13.66 15 12C15 10.34 13.66 9 12 9Z"
                                       Fill="{StaticResource IconBrush}"
                                       Width="16"
                                       Height="16"
                                       Stretch="Uniform"/>
                             </Button>
                             
                             <!-- Delete Button -->
                             <Button Command="{Binding RemoveMediaCommand}"
                                     Background="{StaticResource BackgroundBlockBrush}"
                                     BorderBrush="{StaticResource BorderLineBrush}"
                                     BorderThickness="1"
                                     Width="36"
                                     Height="36">
                                 <Button.Style>
                                     <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                         <Setter Property="Template">
                                             <Setter.Value>
                                                 <ControlTemplate TargetType="Button">
                                                     <Border Background="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             BorderThickness="{TemplateBinding BorderThickness}"
                                                             CornerRadius="18"
                                                             Width="{TemplateBinding Width}"
                                                             Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                 </ControlTemplate>
                                             </Setter.Value>
                                         </Setter>
                                         <Style.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                 <Setter Property="Background" Value="#FFEBEE"/>
                                                 <Setter Property="BorderBrush" Value="#EF5350"/>
                                             </Trigger>
                                         </Style.Triggers>
                                     </Style>
                                 </Button.Style>
                                 
