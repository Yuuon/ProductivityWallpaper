<UserControl x:Class="ProductivityWallpaper.Views.MyThemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">

    <Grid Background="{StaticResource BackgroundMainBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel -->
        <Grid Grid.Column="0" Margin="42,24,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Tab Buttons -->
            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal"
                        Margin="0,0,0,24">
                <Button Content="{DynamicResource MyThemes_UsageHistory}"
                        Command="{Binding ShowUsageHistoryCommand}"
                        Style="{Binding IsUsageHistorySelected, Converter={StaticResource BooleanToTabStyleConverter}}"/>
                <Button Content="{DynamicResource MyThemes_MyWorks}"
                        Command="{Binding ShowMyWorksCommand}"
                        Style="{Binding IsMyWorksSelected, Converter={StaticResource BooleanToTabStyleConverter}}"
                        Margin="16,0,0,0"/>
            </StackPanel>
            
            <!-- Content Area -->
            <Grid Grid.Row="1">
                <!-- Has Content State -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding ThemeItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ThemeCardStyle}"
                                        Margin="0,0,16,16"
                                        MouseLeftButtonDown="OnThemeCardClick">
                                    <Grid>
                                        <!-- Thumbnail -->
                                        <Image Source="{Binding Thumbnail}" 
                                               Stretch="UniformToFill"
                                               ClipToBounds="True">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,316,178" RadiusX="10" RadiusY="10"/>
                                            </Image.Clip>
                                        </Image>
                                        <!-- Type Badge -->
                                        <Border VerticalAlignment="Top" 
                                                HorizontalAlignment="Right"
                                                Background="#AA000000"
                                                CornerRadius="0,10,0,4"
                                                Padding="8,4"
                                                Margin="4">
                                            <TextBlock Text="{Binding Type}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Empty State -->
                <Grid VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Visibility="{Binding HasContent, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel>
                        <!-- No Content Icon -->
                        <Path Data="M724.068 278.015C714.459 278.015 706.669 285.805 706.669 295.414C706.669 301 709.303 305.972 713.393 309.154C713.044 309.611 712.505 310.106 711.782 310.592C710.672 311.339 709.336 311.921 708.194 312.207C707.919 312.275 707.673 312.432 707.496 312.655C707.32 312.877 707.221 313.151 707.216 313.435C707.212 313.719 707.301 313.997 707.47 314.225C707.64 314.453 707.88 314.619 708.153 314.696C710.645 315.408 713.589 315.394 716.153 314.942C717.444 314.714 718.675 314.369 719.737 313.925C720.54 313.589 721.295 313.177 721.909 312.68C722.617 312.767 723.338 312.812 724.068 312.812C733.677 312.812 741.467 305.023 741.467 295.414C741.467 285.805 733.677 278.015 724.068 278.015ZM709.247 295.413C709.247 287.228 715.882 280.592 724.068 280.592C732.253 280.592 738.889 287.228 738.889 295.413C738.889 303.599 732.253 310.234 724.068 310.234C723.259 310.234 722.467 310.17 721.695 310.046C721.488 310.012 721.276 310.03 721.077 310.097C720.879 310.164 720.7 310.279 720.555 310.431C720.22 310.785 719.617 311.181 718.743 311.547C717.886 311.905 716.843 312.203 715.706 312.403C714.927 312.54 714.122 312.63 713.318 312.665C714.594 311.789 715.837 310.59 716.279 309.137C716.359 308.874 716.353 308.592 716.261 308.332C716.169 308.073 715.997 307.849 715.769 307.695C711.831 305.028 709.247 300.522 709.247 295.413Z"
                              Width="64" Height="64"
                              Fill="{StaticResource IconBrush}"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>
                        
                        <!-- Empty Message -->
                        <TextBlock Text="{Binding EmptyMessage}"
                                   Style="{StaticResource BodyTextStyle}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,24"/>
                        
                        <!-- Action Button -->
                        <Button Content="{Binding ActionButtonText}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding EmptyStateActionCommand}"
                                Width="200"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
        
        <!-- Separator Line -->
        <Line Grid.Column="0"
              HorizontalAlignment="Right"
              Y1="0" Y2="1"
              Stretch="UniformToFill"
              Stroke="{StaticResource BorderLineBrush}"
              StrokeThickness="1"/>
        
        <!-- Right Panel - Details -->
        <Grid Grid.Column="1" Margin="24,24,42,24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Visibility="{Binding HasSelectedTheme, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!-- Preview Image -->
                    <Border Style="{StaticResource ThemeCardStyle}"
                            Margin="0,0,0,16">
                        <Image Source="{Binding SelectedTheme.Thumbnail}" 
                               Stretch="UniformToFill"
                               ClipToBounds="True">
                            <Image.Clip>
                                <RectangleGeometry Rect="0,0,316,178" RadiusX="10" RadiusY="10"/>
                            </Image.Clip>
                        </Image>
                    </Border>
                    
                    <!-- Theme Name -->
                    <TextBlock Text="{Binding SelectedTheme.Name}"
                               Style="{StaticResource SubHeaderTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,4"/>
                    
                    <!-- Author -->
                    <TextBlock Text="{Binding SelectedTheme.Author}"
                               Style="{StaticResource CaptionTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    
                    <!-- File Size and Resolution -->
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Run Text="{Binding SelectedTheme.FileSize, StringFormat='{}{0:F1} MB'}" 
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Run Text=" / " 
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Run Text="{Binding SelectedTheme.Resolution}" 
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    </TextBlock>
                    
                    <!-- Tags -->
                    <ItemsControl ItemsSource="{Binding SelectedTheme.Tags}"
                                  Margin="0,0,0,24">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected}"
                                              Style="{StaticResource TagButtonStyle}"
                                              Margin="0,0,8,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Use Now Button -->
                    <Button Content="{DynamicResource MyThemes_UseNow}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding UseThemeCommand}"
                            Height="44"
                            Margin="0,0,0,12"/>
                    
                    <!-- Edit Button -->
                    <Button Content="{DynamicResource MyThemes_Edit}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding EditThemeCommand}"
                            Height="44"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Empty Selection State -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedTheme, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <TextBlock Text="{DynamicResource MyThemes_SelectThemeHint}"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
