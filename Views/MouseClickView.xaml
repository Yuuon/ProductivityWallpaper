<UserControl x:Class="ProductivityWallpaper.Views.MouseClickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ProductivityWallpaper.ViewModels"
             xmlns:models="clr-namespace:ProductivityWallpaper.Models"
             xmlns:converters="clr-namespace:ProductivityWallpaper.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MouseClickViewModel}"
             Background="{StaticResource BackgroundMainBrush}">

    <UserControl.Resources>
        <!-- Region Enter/Exit Animations -->
        <Storyboard x:Key="RegionEnterAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <Storyboard x:Key="RegionExitAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Region Item Template -->
        <DataTemplate x:Key="RegionItemTemplate" DataType="{x:Type models:ClickRegionModel}">
            <Grid Width="{Binding Width, Converter={StaticResource PercentageToPixelConverter}, ConverterParameter={Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}}"
                  Height="{Binding Height, Converter={StaticResource PercentageToPixelConverter}, ConverterParameter={Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}}"
                  Canvas.Left="{Binding X, Converter={StaticResource PercentageToPixelConverter}, ConverterParameter={Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}}"
                  Canvas.Top="{Binding Y, Converter={StaticResource PercentageToPixelConverter}, ConverterParameter={Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}}"
                  Opacity="0">
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource RegionEnterAnimation}"/>
                    </EventTrigger>
                </Grid.Triggers>
                <Rectangle x:Name="RegionRect"
                           Fill="#40FFFFFF"
                           Stroke="#80FFFFFF"
                           StrokeThickness="1"
                           RadiusX="4"
                           RadiusY="4">
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Fill" Value="#60FFFFFF"/>
                                    <Setter Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect ShadowDepth="0" 
                                                               BlurRadius="10" 
                                                               Color="{StaticResource AccentColor}" 
                                                               Opacity="0.5"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
                
                <!-- Region Name Label -->
                <TextBlock Text="{Binding Name}"
                           Foreground="White"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,4">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <!-- Delete Button -->
                <Button x:Name="DeleteButton"
                        Command="{Binding DataContext.DeleteRegionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Width="20"
                        Height="20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-10,-10,0"
                        Background="{StaticResource DangerBrush}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse Fill="{TemplateBinding Background}" Stroke="White" StrokeThickness="1"/>
                                <Path Data="M6 6L14 14 M14 6L6 14"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Width="12"
                                      Height="12"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Media Item Template -->
        <DataTemplate x:Key="MediaItemTemplate" DataType="{x:Type models:MediaItemModel}">
            <Border Background="{StaticResource BackgroundBlockBrush}"
                    BorderBrush="{StaticResource BorderLineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,4"
                    Padding="12"
                    Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                   Command="{Binding DataContext.SetBackgroundMediaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   CommandParameter="{Binding}"/>
                </Border.InputBindings>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Thumbnail or Icon -->
                    <Border Grid.Column="0"
                            Width="48"
                            Height="48"
                            Background="{StaticResource BackgroundMainBrush}"
                            CornerRadius="4"
                            Margin="0,0,12,0">
                        <Grid>
                            <Image Source="{Binding ThumbnailPath}"
                                   Stretch="Uniform"
                                   Visibility="{Binding ThumbnailPath, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                            <Path Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"
                                  Fill="{StaticResource IconBrush}"
                                  Width="24"
                                  Height="24"
                                  Stretch="Uniform"
                                  Visibility="{Binding ThumbnailPath, Converter={StaticResource InverseStringEmptyToVisibilityConverter}}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:MediaFileType.Audio}">
                                                <Setter Property="Data" Value="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="{x:Static models:MediaFileType.Video}">
                                                <Setter Property="Data" Value="M10 16.5l6-4.5-6-4.5v9zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Grid>
                    </Border>
                    
                    <!-- File Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="180"/>
                        
                        <TextBlock Text="{Binding Format, StringFormat='{}{0} file'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Converters need to be defined in App.xaml or here -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <converters:InverseStringEmptyToVisibilityConverter x:Key="InverseStringEmptyToVisibilityConverter"/>
        <converters:BooleanToCursorConverter x:Key="BooleanToCursorConverter"/>
        <converters:DisplayModeToStretchConverter x:Key="DisplayModeToStretchConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
        <converters:PercentageToPixelConverter x:Key="PercentageToPixelConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section 1: Editable Title Bar -->
        <Grid Grid.Row="0" Margin="32,24,42,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Scheme Name Display -->
                <TextBlock Text="{Binding SchemeName, FallbackValue='Mouse Click Scheme'}"
                           Style="{StaticResource SubHeaderTextStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Visibility="{Binding IsEditingName, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                
                 <TextBox Text="{Binding SchemeName, UpdateSourceTrigger=PropertyChanged}"
                          Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         CaretBrush="{StaticResource TextPrimaryBrush}"
                         VerticalAlignment="Center"
                         MinWidth="200"
                         MaxWidth="400"
                         Visibility="{Binding IsEditingName, Converter={StaticResource BooleanToVisibilityConverter}}"
                         LostFocus="OnSchemeNameLostFocus"
                         KeyDown="OnSchemeNameKeyDown"/>
                
                <Button Command="{Binding ToggleEditNameCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <Path Data="M525 148.414H531M528 137.414C528.265 137.149 528.625 137 529 137C529.186 137 529.37 137.037 529.541 137.108C529.713 137.179 529.869 137.283 530 137.414C530.131 137.546 530.235 137.701 530.307 137.873C530.378 138.045 530.414 138.228 530.414 138.414C530.414 138.6 530.378 138.784 530.307 138.955C530.235 139.127 530.131 139.283 530 139.414L521.667 147.748L519 148.414L519.667 145.748L528 137.414Z"
                          Stroke="{StaticResource IconBrush}"
                          StrokeThickness="1.6"
                          Width="16" Height="16"
                          Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Section 2: Page Header -->
        <TextBlock Grid.Row="1"
                   Text="Mouse Click"
                   Style="{StaticResource SubHeaderTextStyle}"
                   Margin="32,16,42,24"/>

        <!-- Section 3: Main Content (2 columns) -->
        <Grid Grid.Row="2" Margin="32,0,42,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Region Editor -->
            <Border Grid.Column="0"
                    Background="{StaticResource BackgroundBlockBrush}"
                    BorderBrush="{StaticResource BorderLineBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header Bar -->
                    <Grid Grid.Row="0" Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Set Click Regions"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            
                            <TextBlock Text="{Binding ScreenResolutionText, StringFormat=' ({0})'}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Add Button -->
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding IsAddingMode, Mode=TwoWay}"
                                      Width="32"
                                      Height="32"
                                      Background="{StaticResource BackgroundMainBrush}"
                                      BorderBrush="{StaticResource BorderLineBrush}"
                                      BorderThickness="1"
                                      Cursor="Hand">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <Path x:Name="PlusIcon"
                                                           Data="M12 5v14M5 12h14"
                                                           Stroke="{StaticResource IconBrush}"
                                                           StrokeThickness="2"
                                                           Width="16"
                                                           Height="16"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </Grid>

                    <!-- Canvas Container -->
                    <Border Grid.Row="1"
                            Background="#333333"
                            CornerRadius="8"
                            Margin="16,0,16,16"
                            SizeChanged="OnCanvasContainerSizeChanged">
                        <Viewbox Stretch="Uniform" Margin="16">
                            <Grid x:Name="CanvasContainer"
                                  Width="1920"
                                  Height="1080">
                                <!-- Background Media -->
                                <Image x:Name="BackgroundImage"
                                       Source="{Binding BackgroundMedia.FilePath}"
                                       Stretch="{Binding BackgroundMedia.DisplayMode, Converter={StaticResource DisplayModeToStretchConverter}}"
                                       Visibility="{Binding BackgroundMedia, Converter={StaticResource NullToVisibilityConverter}}"/>
                                
                                <!-- Canvas for Regions -->
                                <Canvas x:Name="RegionCanvas"
                                        Background="Transparent"
                                        Cursor="{Binding IsAddingMode, Converter={StaticResource BooleanToCursorConverter}}"
                                        MouseLeftButtonDown="OnCanvasMouseLeftButtonDown"
                                        MouseMove="OnCanvasMouseMove"
                                        MouseLeftButtonUp="OnCanvasMouseLeftButtonUp">
                                    
                                    <ItemsControl ItemsSource="{Binding Regions}"
                                                  ItemTemplate="{StaticResource RegionItemTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas IsItemsHost="True"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <!-- Right Column: Media List -->
            <Border Grid.Column="1"
                    Background="{StaticResource BackgroundBlockBrush}"
                    BorderBrush="{StaticResource BorderLineBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="16,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Available Media"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="16,12,16,8"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="12,0,12,12">
                        <ItemsControl ItemsSource="{Binding AvailableMedia}"
                                      ItemTemplate="{StaticResource MediaItemTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvailableMedia.Count}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <StackPanel VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Margin="20">
                                                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                                                   Fill="{StaticResource TextSecondaryBrush}"
                                                                   Width="48"
                                                                   Height="48"
                                                                   Stretch="Uniform"
                                                                   Margin="0,0,0,12"
                                                                   Opacity="0.5"/>
                                                            
                                                            <TextBlock Text="No media available"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       FontSize="13"
                                                                       TextAlignment="Center"/>
                                                            
                                                            <TextBlock Text="Import media in Desktop Background"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       FontSize="11"
                                                                       TextAlignment="Center"
                                                                       Margin="0,4,0,0"
                                                                       Opacity="0.7"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Section 4: Configuration Panel -->
        <Border Grid.Row="3"
                Background="{StaticResource BackgroundBlockBrush}"
                BorderBrush="{StaticResource BorderLineBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Margin="32,0,42,24"
                Visibility="{Binding HasSelectedRegion, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Configure Interaction"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <!-- Import Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="+ Import Image or Video (1 only)"
                            Command="{Binding ImportRegionVisualCommand}"
                            Visibility="{Binding CanAddVisual, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource TextButtonStyle}"
                            Foreground="{StaticResource AccentBrush}"
                            Padding="0,8"
                            Margin="0,0,16,0"/>
                    
                    <Button Content="+ Import Audio (max 5)"
                            Command="{Binding ImportRegionAudioCommand}"
                            Visibility="{Binding CanAddAudio, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource TextButtonStyle}"
                            Foreground="{StaticResource AccentBrush}"
                            Padding="0,8"/>
                </StackPanel>

                <!-- Media Display Area -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Visual Content -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Visual:"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding SelectedRegion.VisualContent, Converter={StaticResource NullToVisibilityConverter}}"/>
                        
                        <Border Background="{StaticResource BackgroundMainBrush}"
                                BorderBrush="{StaticResource BorderLineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Visibility="{Binding SelectedRegion.VisualContent, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M10 16.5l6-4.5-6-4.5v9zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"
                                       Fill="{StaticResource TextSecondaryBrush}"
                                       Width="16"
                                       Height="16"
                                       Stretch="Uniform"
                                       Margin="0,0,8,0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedRegion.VisualContent.Type}" Value="{x:Static models:MediaFileType.Image}">
                                                    <Setter Property="Data" Value="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                
                                <TextBlock Text="{Binding SelectedRegion.VisualContent.FileName}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           MaxWidth="150"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                
                                <Button Command="{Binding RemoveRegionVisualCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,0,0,0"
                                        Cursor="Hand">
                                    <Path Data="M6 6L14 14 M14 6L6 14"
                                           Stroke="{StaticResource TextSecondaryBrush}"
                                           StrokeThickness="2"
                                           Width="12"
                                           Height="12"
                                           Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Audio Content -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Audio:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="16,0,8,0"
                               Visibility="{Binding SelectedRegion.AudioContent.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                        
                        <ItemsControl ItemsSource="{Binding SelectedRegion.AudioContent}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:MediaItemModel}">
                                    <Border Background="{StaticResource BackgroundMainBrush}"
                                            BorderBrush="{StaticResource BorderLineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8"
                                            Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"
                                                   Fill="{StaticResource TextSecondaryBrush}"
                                                   Width="16"
                                                   Height="16"
                                                   Stretch="Uniform"
                                                   Margin="0,0,8,0"/>
                                            
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="12"
                                                       MaxWidth="100"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            
                                            <Button Command="{Binding DataContext.RemoveRegionAudioCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="4,0,0,0"
                                                    Cursor="Hand">
                                                <Path Data="M6 6L14 14 M14 6L6 14"
                                                       Stroke="{StaticResource TextSecondaryBrush}"
                                                       StrokeThickness="2"
                                                       Width="12"
                                                       Height="12"
                                                       Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
