<Application x:Class="ProductivityWallpaper.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProductivityWallpaper"
             xmlns:vm="clr-namespace:ProductivityWallpaper.ViewModels"
             xmlns:views="clr-namespace:ProductivityWallpaper.Views"
             xmlns:converters="clr-namespace:ProductivityWallpaper.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme and Styles -->
                <ResourceDictionary Source="Resources/Theme.xaml"/>
                <!-- Localization loaded dynamically from JSON files -->
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
            <converters:BooleanToTabStyleConverter x:Key="BooleanToTabStyleConverter"/>
            <converters:BooleanToFeatureButtonConverter x:Key="BooleanToFeatureButtonConverter"/>
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <converters:FileSizeConverter x:Key="FileSizeConverter"/>
            <converters:DurationConverter x:Key="DurationConverter"/>
            <converters:MediaTypeIsVideoConverter x:Key="MediaTypeIsVideoConverter"/>
            <converters:MediaTypeIsImageConverter x:Key="MediaTypeIsImageConverter"/>
            <converters:MediaTypeIsAudioConverter x:Key="MediaTypeIsAudioConverter"/>
            <converters:BooleanToActiveTextConverter x:Key="BooleanToActiveTextConverter"/>
            
            <!-- View-ViewModel Mappings -->
            <DataTemplate DataType="{x:Type vm:WallpaperViewModel}">
                <views:WallpaperView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:AiToolViewModel}">
                <views:AiToolView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:WorkshopViewModel}">
                <views:WorkshopView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:MyThemeViewModel}">
                <views:MyThemeView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:CreatorViewModel}">
                <views:CreatorView/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:DesktopBackgroundViewModel}">
                <views:DesktopBackgroundView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
